# =============================================================================
# Supabase (dùng chung cho webclient + webadmin)
# Lấy từ: https://supabase.com/dashboard/project/_/settings/api
# Copy file này thành .env ở root: npm run setup:env
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Chỉ dùng trên server admin — KHÔNG prefix NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# Web Client (apps/webclient) — port 3000
# =============================================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production: https://vinfast3scamau.com
# URL admin CMS — webclient dùng để bật chế độ sửa preview trong iframe
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

# SEO / Local — optional social & verification links
GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GOOGLE_BUSINESS_URL=
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_ZALO_URL=
REDIS_URL=

# Secret dùng chung — admin gọi /api/revalidate trên webclient sau khi lưu CMS
REVALIDATION_SECRET=change-me-to-a-random-string

# =============================================================================
# Web Admin (apps/webadmin) — port 3001
# =============================================================================
# (NEXT_PUBLIC_ADMIN_URL khai báo ở mục Web Client phía trên)

# Gemini API (tùy chọn — nếu dùng tính năng AI trong admin)
GEMINI_API_KEY=

# =============================================================================
# Sau khi điền credentials:
#   1. npm run db:push          — đẩy schema lên Supabase (hoặc db:reset nếu local)
#   2. npm run db:check         — kiểm tra kết nối
#   3. Tạo user admin trong Supabase Dashboard → Authentication → Users
#      Gán app_metadata: { "role": "admin" }
#   4. npm run dev:client & npm run dev:admin
#   5. Mở http://localhost:3001/api/health để xác nhận
# =============================================================================
